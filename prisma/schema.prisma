generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id                  String          @id @default(cuid())
  name                String
  email               String          @unique
  passwordHash        String          @map("password_hash")
  role                String          @default("MEMBER")
  emailVerified       Boolean         @default(false) @map("email_verified")
  twoFactorEnabled    Boolean         @default(false) @map("two_factor_enabled")
  twoFactorSecret     String?         @map("two_factor_secret")
  backupCodes         Json?           @map("backup_codes")
  dashboardView       String          @default("cards") @map("dashboard_view")
  lastLoginAt         DateTime?       @map("last_login_at")
  createdAt           DateTime        @default(now()) @map("created_at")
  advisorActions      AdvisorReport[] @relation("reviewedBy")
  projects            Project[]       @relation("ProjectAccess")
  notificationProjects Project[]      @relation("NotificationUsers")
  notificationPreferences UserNotificationPreference[]
  onboardingProgress OnboardingProgress[]
  accountGroupMemberships AccountGroupMember[]

  @@map("users")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([email])
  @@index([token])
  @@map("password_reset_tokens")
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([email])
  @@index([token])
  @@map("email_verification_tokens")
}

model Project {
  id                   String                 @id @default(cuid())
  name                 String
  industryType         String                 @map("industry_type")
  targetType           String                 @map("target_type")
  targetValue          Float                  @map("target_value")
  tolerancePct         Int                    @default(15) @map("tolerance_pct")
  evaluationWindowDays Int                    @default(7) @map("evaluation_window_days")
  profitMarginPct      Float?                 @map("profit_margin_pct")
  currency             String                 @default("EUR")
  createdAt            DateTime               @default(now()) @map("created_at")
  slackWebhookUrl      String?                @map("slack_webhook_url")
  notificationMode     String                 @default("global") @map("notification_mode") // global, custom, disabled
  analystReports       AnalystReport[]
  projectInvites       ProjectInvite[]
  dataSources          DataSource[]
  incidents            Incident[]
  merchantCenterHealth MerchantCenterHealth[]
  notifications        Notification[]
  users                User[]                 @relation("ProjectAccess")
  notificationUsers    User[]                 @relation("NotificationUsers")
  notificationPreferences UserNotificationPreference[]
  datasets             Dataset[]
  dashboards           Dashboard[]
  personAliases        PersonAlias[]
  rules                Rule[]
  contacts             Contact[]
  invoices             Invoice[]
  companyName          String?                @map("company_name")
  address              String?
  billingEmail         String?                @map("billing_email")
  kvkNumber            String?                @map("kvk_number")
  vatNumber            String?                @map("vat_number")
  contractStart        DateTime?              @map("contract_start")
  contractEnd          DateTime?              @map("contract_end")
  monthlyFee           Float?                 @map("monthly_fee")
  crmNotes             String?                @map("crm_notes")
  accountGroupId       String?                @map("account_group_id")
  accountGroup         AccountGroup?          @relation("AccountGroupProjects", fields: [accountGroupId], references: [id])

  @@index([accountGroupId])
  @@map("projects")
}

model ProjectInvite {
  id        String   @id @default(cuid())
  projectId String   @map("project_id")
  email     String
  token     String   @unique
  status    String   @default("PENDING")
  createdAt DateTime @default(now()) @map("created_at")
  expiresAt DateTime @map("expires_at")
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([token])
  @@index([email])
  @@map("project_invites")
}

model DataSource {
  id             String               @id @default(cuid())
  projectId      String               @map("project_id")
  type           String
  name           String?
  category       String               @default("DATA_SOURCE")
  externalId     String               @map("external_id")
  config         Json?
  token          String               @map("token")
  active         Boolean              @default(true)
  linkedAt       DateTime             @default(now()) @map("linked_at")
  lastSyncedAt   DateTime?            @map("last_synced_at")
  // Sync fields (merged from DataConnection)
  connectorId    String?              @map("connector_id")
  syncInterval   Int                  @default(1440) @map("sync_interval")
  lookbackDays   Int                  @default(30) @map("lookback_days")
  syncStatus     String               @default("ACTIVE") @map("sync_status") // ACTIVE, PAUSED, ERROR
  syncError      String?              @map("sync_error")
  piiEnabled     Boolean              @default(false) @map("pii_enabled")
  // Relations
  project        Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  connector      ConnectorDefinition? @relation(fields: [connectorId], references: [id])
  incidents      Incident[]
  linkedAccounts LinkedAccount[]
  monitoredPages MonitoredPage[]
  uptimeChecks   UptimeCheck[]
  // normalizedData now stored in ClickHouse metrics_data table
  syncJobs       SyncJob[]
  syncAccounts   DataSourceAccount[]
  merchantCenterHealth MerchantCenterHealth[]

  @@index([projectId, type])
  @@index([projectId, syncStatus])
  @@index([connectorId])
  @@index([syncStatus])
  @@index([type])
  @@index([lastSyncedAt])
  @@map("data_sources")
}

model UptimeCheck {
  id           String     @id @default(cuid())
  dataSourceId String     @map("data_source_id")
  status       String
  responseTime Int        @map("response_time")
  statusCode   Int?       @map("status_code")
  checkedAt    DateTime   @default(now()) @map("checked_at")
  dataSource   DataSource @relation(fields: [dataSourceId], references: [id], onDelete: Cascade)

  @@index([dataSourceId, checkedAt])
  @@map("uptime_checks")
}

// NOTE: CampaignMetric data is now stored in ClickHouse (metrics_data table)

model MerchantCenterHealth {
  id                  String      @id @default(cuid())
  projectId           String      @map("project_id")
  dataSourceId        String?     @map("data_source_id")
  date                DateTime
  totalItems          Int         @map("total_items")
  disapprovedItems    Int         @map("disapproved_items")
  disapprovedPct      Float       @map("disapproved_pct")
  topReasons          Json        @map("top_reasons")
  accountIssues       Json        @map("account_issues")
  disapprovedProducts Json?       @map("disapproved_products")
  project             Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  dataSource          DataSource? @relation(fields: [dataSourceId], references: [id], onDelete: SetNull)

  @@index([projectId, date])
  @@index([dataSourceId])
  @@map("merchant_center_health")
}

model AnalystReport {
  id                   String         @id @default(cuid())
  projectId            String         @map("project_id")
  periodStart          DateTime       @map("period_start")
  periodEnd            DateTime       @map("period_end")
  healthScore          Int            @map("health_score")
  healthScoreBreakdown Json           @map("health_score_breakdown")
  deviationPct         Float          @map("deviation_pct")
  trendDirection       String         @map("trend_direction")
  reportJson           Json           @map("report_json")
  inputJson            Json           @map("input_json")
  createdAt            DateTime       @default(now()) @map("created_at")
  advisorReport        AdvisorReport?
  project              Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
  @@index([projectId, periodEnd])
  @@map("analyst_reports")
}

model AdvisorReport {
  id              String        @id @default(cuid())
  analystReportId String        @unique @map("analyst_report_id")
  adviceJson      Json          @map("advice_json")
  status          String        @default("DRAFT")
  reviewedById    String?       @map("reviewed_by_id")
  reviewedAt      DateTime?     @map("reviewed_at")
  executedAt      DateTime?     @map("executed_at")
  notes           String?
  createdAt       DateTime      @default(now()) @map("created_at")
  reviewedBy      User?         @relation("reviewedBy", fields: [reviewedById], references: [id])
  analystReport   AnalystReport @relation(fields: [analystReportId], references: [id], onDelete: Cascade)

  @@index([status])
  @@map("advisor_reports")
}

model PromptLog {
  id         String   @id @default(cuid())
  type       String
  projectId  String   @map("project_id")
  inputJson  Json     @map("input_json")
  outputJson Json     @map("output_json")
  model      String
  tokenCount Int?     @map("token_count")
  latencyMs  Int?     @map("latency_ms")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([projectId, createdAt])
  @@index([type])
  @@map("prompt_logs")
}

model GlobalSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("global_settings")
}

model LinkedAccount {
  id           String     @id @default(cuid())
  dataSourceId String     @map("data_source_id")
  email        String
  name         String?
  role         String?
  status       String     @default("ACTIVE")
  kind         String     @default("USER")
  createdAt    DateTime   @default(now()) @map("created_at")
  dataSource   DataSource @relation(fields: [dataSourceId], references: [id], onDelete: Cascade)

  @@unique([dataSourceId, email])
  @@index([email])
  @@map("linked_accounts")
}

model PersonAlias {
  id           String   @id @default(cuid())
  projectId    String   @map("project_id")
  primaryEmail String   @map("primary_email")
  alias        String
  createdAt    DateTime @default(now()) @map("created_at")
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, alias])
  @@index([projectId, primaryEmail])
  @@map("person_aliases")
}

model UserRole {
  id          String   @id @default(cuid())
  name        String
  description String?
  color       String   @default("#6366f1")
  roleMapping Json     @map("role_mapping")
  isDefault   Boolean  @default(false) @map("is_default")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("user_roles")
}

// ═══════════════════════════════════════════════════════════════════
// ACCOUNT GROUPS (MCC-style grouping)
// ═══════════════════════════════════════════════════════════════════

model AccountGroup {
  id        String               @id @default(cuid())
  name      String               // "Bureau MediaMax", "Evalco Intern"
  slug      String               @unique
  createdAt DateTime             @default(now()) @map("created_at")
  updatedAt DateTime             @updatedAt @map("updated_at")
  members   AccountGroupMember[]
  projects  Project[]            @relation("AccountGroupProjects")

  @@map("account_groups")
}

model AccountGroupMember {
  id             String       @id @default(cuid())
  accountGroupId String       @map("account_group_id")
  userId         String       @map("user_id")
  role           String       @default("MEMBER") // ADMIN, MEMBER, VIEWER
  createdAt      DateTime     @default(now()) @map("created_at")
  accountGroup   AccountGroup @relation(fields: [accountGroupId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([accountGroupId, userId])
  @@index([userId])
  @@map("account_group_members")
}

model Notification {
  id         String   @id @default(cuid())
  projectId  String   @map("project_id")
  type       String
  title      String
  message    String
  severity   String   @default("warning")
  read       Boolean  @default(false)
  url        String?
  statusCode Int?     @map("status_code")
  createdAt  DateTime @default(now()) @map("created_at")
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, read, createdAt])
  @@index([projectId, url, statusCode, read])
  @@index([createdAt])
  @@map("notifications")
}

model MonitoredPage {
  id            String     @id @default(cuid())
  dataSourceId  String     @map("data_source_id")
  url           String
  label         String?
  active        Boolean    @default(true)
  lastStatus    Int?       @map("last_status")
  lastCheckedAt DateTime?  @map("last_checked_at")
  dataSource    DataSource @relation(fields: [dataSourceId], references: [id], onDelete: Cascade)

  @@index([dataSourceId])
  @@map("monitored_pages")
}

model Incident {
  id             String          @id @default(cuid())
  projectId      String          @map("project_id")
  dataSourceId   String?         @map("data_source_id")
  title          String
  cause          String
  causeCode      String?         @map("cause_code")
  status         String          @default("ONGOING")
  severity       String          @default("P3") // P1 (critical), P2 (high), P3 (medium), P4 (low)
  type           String          @default("uptime") // uptime, tracking, data, budget, custom
  assignedTo     String?         @map("assigned_to")
  checkedUrl     String?         @map("checked_url")
  httpMethod     String          @default("GET") @map("http_method")
  statusCode     Int?            @map("status_code")
  responseTime   Float?          @map("response_time")
  resolvedIp     String?         @map("resolved_ip")
  startedAt      DateTime        @default(now()) @map("started_at")
  acknowledgedAt DateTime?       @map("acknowledged_at")
  acknowledgedBy String?         @map("acknowledged_by")
  resolvedAt     DateTime?       @map("resolved_at")
  resolvedBy     String?         @map("resolved_by")
  createdAt      DateTime        @default(now()) @map("created_at")
  events         IncidentEvent[]
  dataSource     DataSource?     @relation(fields: [dataSourceId], references: [id])
  project        Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, status])
  @@index([projectId, createdAt])
  @@index([projectId, severity])
  @@index([dataSourceId])
  @@index([startedAt])
  @@map("incidents")
}

model IncidentEvent {
  id         String   @id @default(cuid())
  incidentId String   @map("incident_id")
  type       String
  message    String?
  userId     String?  @map("user_id")
  userName   String?  @map("user_name")
  createdAt  DateTime @default(now()) @map("created_at")
  incident   Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  @@index([incidentId, createdAt])
  @@map("incident_events")
}

// ═══════════════════════════════════════════════════════════════════
// RULE BUILDER ENGINE
// ═══════════════════════════════════════════════════════════════════

model Rule {
  id              String          @id @default(cuid())
  projectId       String          @map("project_id")
  name            String
  description     String?
  category        String?         // "kosten", "conversie", "uptime", "tracking", "custom"
  enabled         Boolean         @default(true)
  conditions      Json            // [{ sectionOperator: "AND"|"OR", rules: [{ field, fieldSource, operator, value, valueType }] }]
  actions         Json            // [{ type: "incident"|"notification"|"email"|"slack", config: {...} }]
  schedule        String          @default("DAILY") // REALTIME, HOURLY, DAILY
  cooldownMinutes Int             @default(60) @map("cooldown_minutes")
  lastEvaluatedAt DateTime?       @map("last_evaluated_at")
  lastTriggeredAt DateTime?       @map("last_triggered_at")
  createdBy       String          @map("created_by")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")
  project         Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  executions      RuleExecution[]

  @@index([projectId, enabled])
  @@map("rules")
}

model RuleExecution {
  id                String   @id @default(cuid())
  ruleId            String   @map("rule_id")
  triggeredAt       DateTime @default(now()) @map("triggered_at")
  conditionSnapshot Json     @map("condition_snapshot")
  actionsTaken      Json     @map("actions_taken")
  resultData        Json?    @map("result_data")
  success           Boolean  @default(true)
  errorMessage      String?  @map("error_message")
  rule              Rule     @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@index([ruleId, triggeredAt])
  @@map("rule_executions")
}

// ═══════════════════════════════════════════════════════════════════
// DATA INTEGRATION PLATFORM — Universal Data Model
// ═══════════════════════════════════════════════════════════════════

// Catalog of all supported connectors (Google Ads, Meta Ads, GA4, etc.)
model ConnectorDefinition {
  id              String           @id @default(cuid())
  slug            String           @unique // e.g. "google-ads", "meta-ads", "ga4"
  name            String // e.g. "Google Ads", "Meta Ads"
  category        String // PAID_SEARCH, PAID_SOCIAL, ANALYTICS, ORGANIC_SOCIAL, ECOMMERCE, CRM, EMAIL, PROGRAMMATIC, SEO, AFFILIATE, CUSTOM
  authType        String           @map("auth_type") // oauth2, api_key, basic, custom
  oauthScopes     String?          @map("oauth_scopes") // JSON array of required scopes
  apiBaseUrl      String?          @map("api_base_url")
  iconUrl         String?          @map("icon_url")
  description     String?
  isActive        Boolean          @default(true) @map("is_active")
  configSchema    Json?            @map("config_schema") // JSON schema for connection config
  createdAt       DateTime         @default(now()) @map("created_at")
  dataSources     DataSource[]
  dimensions      DimensionDefinition[]
  metrics         MetricDefinition[]
  derivedMetrics  DerivedMetricDefinition[]

  @@index([category])
  @@map("connector_definitions")
}

// Sub-accounts under a data source (e.g., multiple ad accounts under one OAuth)
model DataSourceAccount {
  id              String           @id @default(cuid())
  dataSourceId    String           @map("data_source_id")
  externalId      String           @map("external_id")
  name            String?
  currency        String           @default("EUR")
  timezone        String           @default("Europe/Amsterdam")
  isActive        Boolean          @default(true) @map("is_active")
  createdAt       DateTime         @default(now()) @map("created_at")
  dataSource      DataSource       @relation(fields: [dataSourceId], references: [id], onDelete: Cascade)
  // normalizedData now stored in ClickHouse metrics_data table

  @@unique([dataSourceId, externalId])
  @@index([dataSourceId])
  @@map("data_source_accounts")
}

// Definition of a dimension for a connector (what can be split/grouped by)
model DimensionDefinition {
  id              String              @id @default(cuid())
  connectorId     String              @map("connector_id")
  slug            String              // e.g. "campaign_name", "device", "country"
  name            String              // Human-readable: "Campaign Name", "Device", "Country"
  canonicalName   String?             @map("canonical_name") // Maps to universal dimension
  level           String?             // Which data level this dimension applies to (campaign, ad_group, ad)
  dataType        String              @default("STRING") @map("data_type") // STRING, NUMBER, DATE, BOOLEAN
  description     String?
  isDefault       Boolean             @default(false) @map("is_default") // Included by default in fetches
  createdAt       DateTime            @default(now()) @map("created_at")
  connector       ConnectorDefinition @relation(fields: [connectorId], references: [id], onDelete: Cascade)

  @@unique([connectorId, slug, level])
  @@index([connectorId])
  @@index([canonicalName])
  @@map("dimension_definitions")
}

// Definition of a metric for a connector (what can be measured)
model MetricDefinition {
  id              String              @id @default(cuid())
  connectorId     String              @map("connector_id")
  slug            String              // e.g. "impressions", "clicks", "cost"
  name            String              // Human-readable: "Impressions", "Clicks", "Cost"
  canonicalName   String?             @map("canonical_name") // Maps to universal metric
  level           String?             // Which data level this metric applies to
  dataType        String              @default("NUMBER") @map("data_type") // NUMBER, CURRENCY, PERCENTAGE, DURATION
  aggregationType String              @default("SUM") @map("aggregation_type") // SUM, AVG, MIN, MAX, NONE (non-aggregatable)
  description     String?
  isDefault       Boolean             @default(false) @map("is_default") // Included by default in fetches
  createdAt       DateTime            @default(now()) @map("created_at")
  connector       ConnectorDefinition @relation(fields: [connectorId], references: [id], onDelete: Cascade)

  @@unique([connectorId, slug, level])
  @@index([connectorId])
  @@index([canonicalName])
  @@map("metric_definitions")
}

// NOTE: NormalizedMetric data is now stored in ClickHouse (metrics_data table)
// See: scripts/clickhouse-init/clickhouse-init.sql for the schema
// See: src/lib/clickhouse-queries.ts for the query layer

// Dataset definitions — logical groupings for dashboard reporting
model Dataset {
  id              String          @id @default(cuid())
  projectId       String          @map("project_id")
  slug            String          // e.g. "paid-performance", "seo-performance"
  name            String          // "Paid Advertising Performance"
  description     String?
  isSystem        Boolean         @default(false) @map("is_system") // Pre-built vs custom
  config          Json?           // { selectedDimensions: [...], selectedMetrics: [...], filters: [...] }
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")
  project         Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sources         DatasetSource[]

  @@unique([projectId, slug])
  @@index([projectId])
  @@map("datasets")
}

// Links datasets to their data sources
model DatasetSource {
  id              String         @id @default(cuid())
  datasetId       String         @map("dataset_id")
  dataSourceId    String         @map("data_source_id")
  level           String?        // Which level from this source feeds this dataset
  dimensionMapping Json?         @map("dimension_mapping")
  metricMapping   Json?          @map("metric_mapping")
  createdAt       DateTime       @default(now()) @map("created_at")
  dataset         Dataset        @relation(fields: [datasetId], references: [id], onDelete: Cascade)

  @@unique([datasetId, dataSourceId, level])
  @@index([datasetId])
  @@map("dataset_sources")
}

// ═══════════════════════════════════════════════════════════════════
// CUSTOM DASHBOARDS
// ═══════════════════════════════════════════════════════════════════

model Dashboard {
  id          String            @id @default(cuid())
  projectId   String            @map("project_id")
  name        String
  description String?
  starred     Boolean           @default(false)
  filters     Json?             // [{ dimension, operator, values }]
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")
  project     Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  widgets     DashboardWidget[]

  @@index([projectId])
  @@map("dashboards")
}

model DashboardWidget {
  id          String    @id @default(cuid())
  dashboardId String    @map("dashboard_id")
  type        String    // kpi, line_chart, bar_chart, pie_chart, table, text
  title       String
  position    Json      // { x, y, w, h } grid position
  sortOrder   Int       @default(0) @map("sort_order")
  config      Json?     // { metric, metrics, dimensions, compareMode, limit, text, ... }
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  dashboard   Dashboard @relation(fields: [dashboardId], references: [id], onDelete: Cascade)

  @@index([dashboardId])
  @@map("dashboard_widgets")
}

// Derived/calculated metric definitions (CTR = clicks/impressions, ROAS = revenue/cost)
model DerivedMetricDefinition {
  id              String              @id @default(cuid())
  connectorId     String?             @map("connector_id") // null = universal/cross-platform
  projectId       String?             @map("project_id") // null = system-wide
  slug            String
  name            String
  formula         String              // e.g. "clicks / impressions * 100" or "conversion_value / cost"
  inputMetrics    Json                @map("input_metrics") // ["clicks", "impressions"]
  outputType      String              @default("PERCENTAGE") @map("output_type") // PERCENTAGE, CURRENCY, NUMBER, RATIO
  description     String?
  createdAt       DateTime            @default(now()) @map("created_at")
  connector       ConnectorDefinition? @relation(fields: [connectorId], references: [id], onDelete: Cascade)

  @@index([connectorId])
  @@index([projectId])
  @@map("derived_metric_definitions")
}

// Sync job tracking — each data fetch operation
model SyncJob {
  id              String     @id @default(cuid())
  dataSourceId    String     @map("data_source_id")
  status          String     @default("PENDING") // PENDING, RUNNING, COMPLETED, FAILED, CANCELLED
  syncMode        String     @default("INCREMENTAL") @map("sync_mode") // INCREMENTAL, FULL, DELTA
  level           String?    // Which level(s) were synced
  dateFrom        DateTime?  @map("date_from")
  dateTo          DateTime?  @map("date_to")
  recordsFetched  Int?       @map("records_fetched")
  recordsStored   Int?       @map("records_stored")
  recordsNew      Int?       @map("records_new")
  recordsUpdated  Int?       @map("records_updated")
  recordsDeleted  Int?       @map("records_deleted")
  recordsSkipped  Int?       @map("records_skipped")
  errorMessage    String?    @map("error_message")
  startedAt       DateTime?  @map("started_at")
  completedAt     DateTime?  @map("completed_at")
  createdAt       DateTime   @default(now()) @map("created_at")
  dataSource      DataSource @relation(fields: [dataSourceId], references: [id], onDelete: Cascade)
  logs            SyncLog[]

  @@index([dataSourceId])
  @@index([dataSourceId, status])
  @@index([status, createdAt])
  @@index([createdAt])
  @@map("sync_jobs")
}

// Detailed logs for sync operations
model SyncLog {
  id        String   @id @default(cuid())
  jobId     String   @map("job_id")
  level     String   @default("INFO") // DEBUG, INFO, WARN, ERROR
  message   String
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")
  job       SyncJob  @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId, createdAt])
  @@map("sync_logs")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?  @map("user_id")
  action    String   // LOGIN, LOGIN_FAILED, 2FA_ENABLED, 2FA_DISABLED, PASSWORD_CHANGED, ADMIN_ACTION, etc.
  target    String?  // Target resource (e.g., user ID, project ID)
  details   String?  // Additional context
  ip        String?  // Client IP address
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@map("audit_logs")
}

model UserNotificationPreference {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  projectId String   @map("project_id")
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
  @@map("user_notification_preferences")
}

// Onboarding progress tracking per user
model OnboardingProgress {
  id          String    @id @default(cuid())
  userId      String    @map("user_id")
  step        String    // "profile", "project", "sources", "monitoring", "notifications", "team"
  completed   Boolean   @default(false)
  skipped     Boolean   @default(false)
  completedAt DateTime? @map("completed_at")
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, step])
  @@index([userId])
  @@map("onboarding_progress")
}

// CRM: Contact persons per project
model Contact {
  id        String   @id @default(cuid())
  projectId String   @map("project_id")
  name      String
  email     String?
  phone     String?
  role      String?  // "Beslisser", "Marketing Manager", etc.
  isPrimary Boolean  @default(false) @map("is_primary")
  notes     String?
  createdAt DateTime @default(now()) @map("created_at")
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("contacts")
}

// CRM: Invoices per project
model Invoice {
  id            String    @id @default(cuid())
  projectId     String    @map("project_id")
  invoiceNumber String    @unique @map("invoice_number")
  amount        Float
  vatAmount     Float     @default(0) @map("vat_amount")
  status        String    @default("CONCEPT") // CONCEPT, VERZONDEN, BETAALD, VERLOPEN
  invoiceDate   DateTime  @map("invoice_date")
  dueDate       DateTime  @map("due_date")
  paidAt        DateTime? @map("paid_at")
  description   String?
  notes         String?
  createdAt     DateTime  @default(now()) @map("created_at")
  project       Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([status])
  @@map("invoices")
}

// AI Data Chat sessions
model AiChatSession {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  projectId String   @map("project_id")
  title     String   @default("Nieuwe Chat")
  messages  String   @default("[]") // JSON array of {role, content, timestamp}
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId, projectId])
  @@map("ai_chat_sessions")
}
